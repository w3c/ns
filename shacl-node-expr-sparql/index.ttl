# W3C SHACL Node Expressions Vocabulary

# THIS VERSION IS UNDER DEVELOPMENT BY THE DATA-SHAPES (SHACL 1.2) WG

@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix shnex:   <http://www.w3.org/ns/shacl-node-expr#> .
@prefix shnex-sparql: <http://www.w3.org/ns/shacl-node-expr-sparql#> .
@prefix sparql:  <http://www.w3.org/ns/sparql#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

shnex-sparql:
	a owl:Ontology ;
	owl:imports <http://www.w3.org/ns/shacl-node-expr#>  ;
	owl:versionIRI shnex-sparql:1.2 ;
	rdfs:label "W3C SHACL SPARQL Extensions Vocabulary"@en ;
	rdfs:comment "This vocabulary defines terms used in the SHACL SPARQL specification."@en ;
    dcterms:creator "W3C Data Shapes Working Group" ;
    dcterms:publisher "World Wide Web Consortium" ;
    # dcterms:created ""^^xsd:date ;
    # dcterms:issued ""^^xsd:date ;
    # dcterms:modified ""^^xsd:date ;
    dcterms:license "https://www.w3.org/copyright/software-license/"^^xsd:anyURI ;
	sh:declare [
		sh:prefix "shnex-sparql" ;
		sh:namespace "http://www.w3.org/ns/shacl-node-expr-sparql#"^^xsd:anyURI ;
	] ;
.


shnex-sparql:category
	a rdf:Property ;
	rdfs:label "category"@en ;
	rdfs:comment "Indicates the category of a SPARQL function, such as algebraic, numeric, string, date, or other."@en ;
	rdfs:domain sh:ListParameterExpressionFunction ;
	rdfs:range xsd:string ;
	.

shnex-sparql:example
	a rdf:Property ;
	rdfs:label "example"@en ;
	rdfs:comment "Provides an example usage of the SPARQL function or form."@en ;
	rdfs:domain sh:ListParameterExpressionFunction ;
	rdfs:range xsd:string ;
	.

shnex-sparql:infixOperator
	a rdf:Property ;
	rdfs:label "infix operator"@en ;
	rdfs:comment "Indicates the infix operator symbol used in SPARQL syntax for this function, enabling conversion from functional form to infix notation."@en ;
	rdfs:domain sh:ListParameterExpressionFunction ;
	rdfs:range xsd:string ;
	.


# Spec link pattern:
# For functions in the source whose rdfs:isDefinedBy is the generic spec homepage
# <http://www.w3.org/TR/sparql12-query/> a per-function anchor was constructed
# as <http://www.w3.org/TR/sparql12-query/#func-LOCALNAME> where LOCALNAME is
# the SPARQL local name (e.g., sparql:str -> #func-str). Where a function had a
# more specific anchor in the source, the same target was used. (This comment
# documents the fragment pattern used for constructed links.)

# Imported SPARQL function terms (rdf:type, rdfs:label, rdfs:comment, shnex-sparql:category, rdfs:isDefinedBy)
# Category values: algebraic, numeric, string, date, other



sparql:plus
    a sh:ListParameterExpressionFunction ;
	rdfs:label "plus"@en ;
	rdfs:comment "This operator adds two numeric expressions and returns their sum."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "algebraic" ;
	shnex-sparql:infixOperator "+" ;
	shnex-sparql:example """[ sparql:plus ( 38 4 ) ]""" ;
	.

sparql:subtract
	a sh:ListParameterExpressionFunction ;
	rdfs:label "subtract"@en ;
	rdfs:comment "This operator subtracts the second numeric expression from the first and returns the result."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "algebraic" ;
	shnex-sparql:infixOperator "-" ;
	shnex-sparql:example """[ sparql:subtract ( 42 7 ) ]""" ;
	.

sparql:multiply
	a sh:ListParameterExpressionFunction ;
	rdfs:label "multiply"@en ;
	rdfs:comment "This operator multiplies two numeric expressions and returns the product."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "algebraic" ;
	shnex-sparql:infixOperator "*" ;
	shnex-sparql:example """[ sparql:multiply ( 6 7 ) ]""" ;
	.

sparql:divide
	a sh:ListParameterExpressionFunction ;
	rdfs:label "divide"@en ;
	rdfs:comment "This operator divides the first numeric expression by the second and returns the result."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "algebraic" ;
	shnex-sparql:infixOperator "/" ;
	shnex-sparql:example """[ sparql:divide ( 84 2 ) ]""" ;
	.

sparql:unary-minus
	a sh:ListParameterExpressionFunction ;
	rdfs:label "unary minus"@en ;
	rdfs:comment "This unary operator returns the negation of a numeric expression."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "algebraic" ;
	shnex-sparql:example """[ sparql:unary-minus ( 42 ) ]""" ;
	.

sparql:unary-plus
	a sh:ListParameterExpressionFunction ;
	rdfs:label "unary plus"@en ;
	rdfs:comment "This unary operator returns the numeric expression unchanged, acting primarily as a syntactic indicator."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "algebraic" ;
	shnex-sparql:example """[ sparql:unary-plus ( 42 ) ]""" ;
	.

sparql:equals
	a sh:ListParameterExpressionFunction ;
	rdfs:label "equals"@en ;
	rdfs:comment "This operator compares two expressions for equality."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "=" ;
	shnex-sparql:example """[ sparql:equals ( "hello" "hello" ) ]""" ;
	.

sparql:not-equals
	a sh:ListParameterExpressionFunction ;
	rdfs:label "not equals"@en ;
	rdfs:comment "This operator tests two expressions for inequality."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "!=" ;
	shnex-sparql:example """[ sparql:not-equals ( "hello" "world" ) ]""" ;
	.

sparql:greater-than
	a sh:ListParameterExpressionFunction ;
	rdfs:label "greater than"@en ;
	rdfs:comment "This operator tests whether the first RDF term is greater than the second RDF term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator ">" ;
	shnex-sparql:example """[ sparql:greater-than ( 10 5 ) ]""" ;
	.

sparql:less-than
	a sh:ListParameterExpressionFunction ;
	rdfs:label "less than"@en ;
	rdfs:comment "This operator tests whether the first RDF term is less than the second RDF term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "<" ;
	shnex-sparql:example """[ sparql:less-than ( 5 10 ) ]""" ;
	.

sparql:greater-than-or-equal
	a sh:ListParameterExpressionFunction ;
	rdfs:label "greater than or equal"@en ;
	rdfs:comment "This operator tests whether the first RDF term is greater than or equal to the second RDF term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator ">=" ;
	shnex-sparql:example """[ sparql:greater-than-or-equal ( 10 10 ) ]""" ;
	.

sparql:less-than-or-equal
	a sh:ListParameterExpressionFunction ;
	rdfs:label "less than or equal"@en ;
	rdfs:comment "This operator tests whether the first RDF term is less than or equal to the second RDF term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "<=" ;
	shnex-sparql:example """[ sparql:less-than-or-equal ( 5 5 ) ]""" ;
	.

sparql:logical-not
	a sh:ListParameterExpressionFunction ;
	rdfs:label "logical not"@en ;
	rdfs:comment "This form computes the logical NOT of a boolean expression."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:logical-not ( true ) ]""" ;
	.

# Functional forms
sparql:bound
	a sh:ListParameterExpressionFunction ;
	rdfs:label "bound"@en ;
	rdfs:comment "This form checks whether a variable is bound (assigned a value) in the current solution."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-bound> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:bound ( [ shnex:var "var" ] ) ]""" ;
	.

sparql:if
	a sh:ListParameterExpressionFunction ;
	rdfs:label "if"@en ;
	rdfs:comment "This conditional form evaluates a test expression and returns one of two provided expressions based on the boolean outcome of the test."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-if> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:if ( [ sparql:greater-than ( 10 5 ) ] "big" "small" ) ]""" ;
	.

sparql:coalesce
	a sh:ListParameterExpressionFunction ;
	rdfs:label "coalesce"@en ;
	rdfs:comment "This form returns the first non-error, non-unbound value from a sequence of expressions."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-coalesce> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:coalesce ( [ shnex:var "optionalValue" ] \"default\" ) ]""" ;
	.

sparql:logical-or
	a sh:ListParameterExpressionFunction ;
	rdfs:label "logical or"@en ;
	rdfs:comment "This form computes the logical OR of two boolean expressions."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-logical-or> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "||" ;
	shnex-sparql:example """[ sparql:logical-or ( true false ) ]""" ;
	.

sparql:logical-and
	a sh:ListParameterExpressionFunction ;
	rdfs:label "logical and"@en ;
	rdfs:comment "This form computes the logical AND of two boolean expressions."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-logical-and> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "&&" ;
	shnex-sparql:example """[ sparql:logical-and ( true true ) ]""" ;
	.

# Functions on RDF terms
sparql:sameTerm
	a sh:ListParameterExpressionFunction ;
	rdfs:label "same term"@en ;
	rdfs:comment "This function checks whether two RDF terms are the same in the strict sense, including their lexical forms, datatypes, and language tags for literals."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-sameTerm> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "=" ;
	shnex-sparql:example """[ sparql:sameTerm ( "hello" "hello" ) ]""" ;
	.

sparql:sameValue
	a sh:ListParameterExpressionFunction ;
	rdfs:label "same value"@en ;
	rdfs:comment "This function compares two RDF terms for equivalent RDF values, potentially considering numeric type equivalencies and other canonical forms beyond strict term identity."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-sameValue> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:infixOperator "=" ;
	shnex-sparql:example """[ sparql:sameValue ( 42 "42"^^xsd:integer ) ]""" ;
	.

sparql:isIRI
	a sh:ListParameterExpressionFunction ;
	rdfs:label "is iri"@en ;
	rdfs:comment "This function returns true if the provided term is an IRI, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-isIRI> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:isIRI ( ex:resource ) ]""" ;
	.

sparql:isURI
	a sh:ListParameterExpressionFunction ;
	rdfs:label "is uri"@en ;
	rdfs:comment "This function returns true if the provided term is an IRI, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-isIRI> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:isURI ( ex:resource ) ]""" ;
	.

sparql:isBlank
	a sh:ListParameterExpressionFunction ;
	rdfs:label "is blank"@en ;
	rdfs:comment "This function returns true if the provided term is a blank node, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-isBlank> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example "[ sparql:isBlank ( _:blankNode ) ]" ;
	.

sparql:isLiteral
	a sh:ListParameterExpressionFunction ;
	rdfs:label "is literal"@en ;
	rdfs:comment "This function returns true if the provided term is an RDF literal, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-isLiteral> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:isLiteral ( "hello world" ) ]""" ;
	.

sparql:isNumeric
	a sh:ListParameterExpressionFunction ;
	rdfs:label "is numeric"@en ;
	rdfs:comment "This function returns true if the provided term is a numeric literal (e.g., xsd:integer, xsd:decimal, xsd:float, or xsd:double), and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-isNumeric> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:isNumeric ( 42 ) ]""" ;
	.

sparql:str
	a sh:ListParameterExpressionFunction ;
	rdfs:label "str"@en ;
	rdfs:comment "This function returns the lexical form of an RDF term, which for IRIs is the IRI string, and for literals is the lexical representation."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-str> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:str ( 42 ) ]""" ;
	.

sparql:lang
	a sh:ListParameterExpressionFunction ;
	rdfs:label "lang"@en ;
	rdfs:comment "This function returns the language tag of a literal, or an empty string if no language tag is present or the term is not a literal."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-lang> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:lang ( "hello"@en ) ]""" ;
	.

sparql:langdir
	a sh:ListParameterExpressionFunction ;
	rdfs:label "langdir"@en ;
	rdfs:comment "This function returns the initial text direction of a literal."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-langdir> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example "[ sparql:langdir ( \"hello\"@en--ltr ) ]" ;
	.

sparql:hasLang
	a sh:ListParameterExpressionFunction ;
	rdfs:label "has lang"@en ;
	rdfs:comment "This function returns true if the given RDF literal has a specified language, matching the literal’s language tag."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-haslang> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:hasLang ( "hello"@en "en" ) ]""" ;
	.

sparql:hasLangdir
	a sh:ListParameterExpressionFunction ;
	rdfs:label "has langdir"@en ;
	rdfs:comment "This function returns true if the given RDF literal has an initial text direction."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-haslangdir> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example "[ sparql:hasLangdir ( \"hello\"@en--ltr ) ]" ;
	.

sparql:datatype
	a sh:ListParameterExpressionFunction ;
	rdfs:label "datatype"@en ;
	rdfs:comment "This function returns the datatype IRI of a literal term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-datatype> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:datatype ( "42"^^xsd:integer ) ]""" ;
	.

sparql:iri
	a sh:ListParameterExpressionFunction ;
	rdfs:label "iri"@en ;
	rdfs:comment "This function returns an IRI with the given string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-iri> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:iri ( "http://example.com/ns#resource" ) ]""" ;
	.

sparql:uri
	a sh:ListParameterExpressionFunction ;
	rdfs:label "uri"@en ;
	rdfs:comment "This function returns an IRI with the given string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-uri> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:uri ( "http://example.com/ns#resource" ) ]""" ;
	.

sparql:bnode
	a sh:ListParameterExpressionFunction ;
	rdfs:label "bnode"@en ;
	rdfs:comment "This function returns a blank node."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-bnode> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:bnode () ]""" ;
	.

sparql:strdt
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strdt"@en ;
	rdfs:comment "This function creates a typed literal from a string and a datatype IRI, returning an RDF literal with the specified lexical form and datatype."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strdt> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strdt ( "42" xsd:integer ) ]""" ;
	.

sparql:strlang
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strlang"@en ;
	rdfs:comment "This function creates an RDF literal with the specified lexical form and language tag."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strlang> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strlang ( "hello" "en" ) ]""" ;
	.

sparql:strlangdir
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strlangdir"@en ;
	rdfs:comment "This function creates an RDF literal with language tag and initial text direction."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strlangdir> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example "[ sparql:strlangdir ( \"hello\" \"en\" \"ltr\" ) ]" ;
	.

sparql:uuid
	a sh:ListParameterExpressionFunction ;
	rdfs:label "uuid"@en ;
	rdfs:comment "This function generates a UUID as an IRI."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-uuid> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:uuid () ]""" ;
	.

sparql:struuid
	a sh:ListParameterExpressionFunction ;
	rdfs:label "struuid"@en ;
	rdfs:comment "This function generates a UUID as a string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-struuid> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:struuid () ]""" ;
	.

# Functions on strings
sparql:strlen
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strlen"@en ;
	rdfs:comment "This function returns the length of the lexical form of a string literal, measured in characters."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strlen> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strlen ( "hello" ) ]""" ;
	.

sparql:substr
	a sh:ListParameterExpressionFunction ;
	rdfs:label "substr"@en ;
	rdfs:comment "This function returns the substring of the given string starting at a specified position and optionally limited to a given length."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-substr> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:substr ( "hello world" 2 5 ) ]""" ;
	.

sparql:ucase
	a sh:ListParameterExpressionFunction ;
	rdfs:label "ucase"@en ;
	rdfs:comment "This function transforms all alphabetic characters in the input string to uppercase, following Unicode case-folding conventions."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-ucase> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:ucase ( "hello" ) ]""" ;
	.

sparql:lcase
	a sh:ListParameterExpressionFunction ;
	rdfs:label "lcase"@en ;
	rdfs:comment "This function transforms all alphabetic characters in the input string to lowercase, according to Unicode case-folding rules."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-lcase> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:lcase ( "HELLO" ) ]""" ;
	.

sparql:strstarts
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strstarts"@en ;
	rdfs:comment "This function returns true if the first string argument begins with the second string argument, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strstarts> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strstarts ( "hello world" "hello" ) ]""" ;
	.

sparql:strends
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strends"@en ;
	rdfs:comment "This function returns true if the first string argument ends with the second string argument, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strends> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strends ( "hello world" "world" ) ]""" ;
	.

sparql:contains
	a sh:ListParameterExpressionFunction ;
	rdfs:label "contains"@en ;
	rdfs:comment "This function returns true if the first string argument contains the second string argument as a substring, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-contains> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:contains ( "hello world" "lo wo" ) ]""" ;
	.

sparql:strbefore
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strbefore"@en ;
	rdfs:comment "This function returns the substring of the first argument that precedes the first occurrence of the second argument."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strbefore> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strbefore ( "hello world" " " ) ]""" ;
	.

sparql:strafter
	a sh:ListParameterExpressionFunction ;
	rdfs:label "strafter"@en ;
	rdfs:comment "This function returns the substring of the first argument that follows the first occurrence of the second argument."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-strafter> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:strafter ( "hello world" " " ) ]""" ;
	.

sparql:concat
	a sh:ListParameterExpressionFunction ;
	rdfs:label "concat"@en ;
	rdfs:comment "This function concatenates two or more string literals into one continuous string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-concat> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:concat ( "hello" " " "world" ) ]""" ;
	.

sparql:langMatches
	a sh:ListParameterExpressionFunction ;
	rdfs:label "langmatches"@en ;
	rdfs:comment "This function checks whether a given language tag matches a specified language range."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-langMatches> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:langMatches ( "en-US" "en" ) ]""" ;
	.

sparql:regex
	a sh:ListParameterExpressionFunction ;
	rdfs:label "regex"@en ;
	rdfs:comment "This function tests whether a string matches a regular expression pattern, optionally with a specified flag (e.g., i for case-insensitive)."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-regex> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:regex ( "hello123" "[0-9]+" ) ]""" ;
	.

sparql:replace
	a sh:ListParameterExpressionFunction ;
	rdfs:label "replace"@en ;
	rdfs:comment "This function performs a regular expression search-and-replace on a string, returning the modified string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-replace> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:replace ( "hello world" "world" "universe" ) ]""" ;
	.

sparql:encode
	a sh:ListParameterExpressionFunction ;
	rdfs:label "encode"@en ;
	rdfs:comment "This function encodes a string using a specified method (e.g., URI-encoding), returning the encoded version."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-encode> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "string" ;
	shnex-sparql:example """[ sparql:encode ( "hello world" "UTF-8" ) ]""" ;
	.

# Functions on numbers
sparql:abs
	a sh:ListParameterExpressionFunction ;
	rdfs:label "abs"@en ;
	rdfs:comment "This function returns the absolute value of a numeric argument."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-abs> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "numeric" ;
	shnex-sparql:example """[ sparql:abs ( -42 ) ]""" ;
	.

sparql:round
	a sh:ListParameterExpressionFunction ;
	rdfs:label "round"@en ;
	rdfs:comment "This function rounds a numeric argument to the nearest integer."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-round> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "numeric" ;
	shnex-sparql:example """[ sparql:round ( 3.7 ) ]""" ;
	.

sparql:ceil
	a sh:ListParameterExpressionFunction ;
	rdfs:label "ceil"@en ;
	rdfs:comment "This function returns the smallest integer greater than or equal to the numeric argument."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-ceil> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "numeric" ;
	shnex-sparql:example """[ sparql:ceil ( 3.2 ) ]""" ;
	.

sparql:floor
	a sh:ListParameterExpressionFunction ;
	rdfs:label "floor"@en ;
	rdfs:comment "This function returns the greatest integer less than or equal to the numeric argument."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-floor> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "numeric" ;
	shnex-sparql:example """[ sparql:floor ( 3.8 ) ]""" ;
	.

sparql:rand
	a sh:ListParameterExpressionFunction ;
	rdfs:label "rand"@en ;
	rdfs:comment "This function returns a random number between 0 and 1."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-rand> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "numeric" ;
	shnex-sparql:example """[ sparql:rand () ]""" ;
	.

# Functions on datetimes
sparql:now
	a sh:ListParameterExpressionFunction ;
	rdfs:label "now"@en ;
	rdfs:comment "This function returns the current dateTime (with or without a timezone) at the moment of query execution."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-now> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:now () ]""" ;
	.

sparql:year
	a sh:ListParameterExpressionFunction ;
	rdfs:label "year"@en ;
	rdfs:comment "This function returns the year component of an xsd:dateTime or xsd:date."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-year> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:year ( "2023-12-25T10:30:00"^^xsd:dateTime ) ]""" ;
	.

sparql:month
	a sh:ListParameterExpressionFunction ;
	rdfs:label "month"@en ;
	rdfs:comment "This function returns the month component of an xsd:dateTime or xsd:date."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-month> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:month ( "2023-12-25T10:30:00"^^xsd:dateTime ) ]""" ;
	.

sparql:day
	a sh:ListParameterExpressionFunction ;
	rdfs:label "day"@en ;
	rdfs:comment "This function returns the day component of an xsd:dateTime or xsd:date."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-day> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:day ( "2023-12-25T10:30:00"^^xsd:dateTime ) ]""" ;
	.

sparql:hours
	a sh:ListParameterExpressionFunction ;
	rdfs:label "hours"@en ;
	rdfs:comment "This function returns the hour component (0–23) of an xsd:dateTime value."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-hours> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:hours ( "2023-12-25T10:30:00"^^xsd:dateTime ) ]""" ;
	.

sparql:minutes
	a sh:ListParameterExpressionFunction ;
	rdfs:label "minutes"@en ;
	rdfs:comment "This function returns the minute component (0–59) of an xsd:dateTime value."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-minutes> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:minutes ( "2023-12-25T10:30:00"^^xsd:dateTime ) ]""" ;
	.

sparql:seconds
	a sh:ListParameterExpressionFunction ;
	rdfs:label "seconds"@en ;
	rdfs:comment "This function returns the seconds component of a valid xsd:dateTime or xsd:dateTimeStamp value."@en ;
	shnex-sparql:category "date" ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-seconds> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:seconds ( "2023-12-25T10:30:00"^^xsd:dateTime ) ]""" ;
	.

sparql:timezone
	a sh:ListParameterExpressionFunction ;
	rdfs:label "timezone"@en ;
	rdfs:comment "This function returns the timezone component as an xsd:dayTimeDuration for an xsd:dateTime value with a specified time zone, or an empty value if none."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-timezone> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:timezone ( "2023-12-25T10:30:00+02:00"^^xsd:dateTime ) ]""" ;
	.

sparql:tz
	a sh:ListParameterExpressionFunction ;
	rdfs:label "tz"@en ;
	rdfs:comment "This function returns the timezone component as a string in ISO 8601 format if present in the xsd:dateTime value, or an empty string otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-tz> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "date" ;
	shnex-sparql:example """[ sparql:tz ( "2023-12-25T10:30:00+02:00"^^xsd:dateTime ) ]""" ;
	.

# Functions on triple terms
sparql:triple
	a sh:ListParameterExpressionFunction ;
	rdfs:label "triple"@en ;
	rdfs:comment "This function constructs a triple term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-triple> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example "[ sparql:triple ( ex:s ex:p ex:o ) ]" ;
	.

sparql:subject
	a sh:ListParameterExpressionFunction ;
	rdfs:label "subject"@en ;
	rdfs:comment "This function returns the subject of a triple term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-subject> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example "[ sparql:subject ( << ex:s ex:p ex:o >> ) ]" ;
	.

sparql:predicate
	a sh:ListParameterExpressionFunction ;
	rdfs:label "predicate"@en ;
	rdfs:comment "This function returns the predicate of a triple term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-predicate> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example "[ sparql:predicate ( << ex:s ex:p ex:o >> ) ]" ;
	.

sparql:object
	a sh:ListParameterExpressionFunction ;
	rdfs:label "object"@en ;
	rdfs:comment "This function returns the object of a triple term."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-object> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example "[ sparql:object ( << ex:s ex:p ex:o >> ) ]" ;
	.

sparql:isTriple
	a sh:ListParameterExpressionFunction ;
	rdfs:label "is triple"@en ;
	rdfs:comment "This function returns true if the argument is a triple term, and false otherwise."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-isTriple> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example "[ sparql:isTriple ( << ex:s ex:p ex:o >> ) ]" ;
	.

# Hash functions
sparql:md5
	a sh:ListParameterExpressionFunction ;
	rdfs:label "md5"@en ;
	rdfs:comment "This function computes the MD5 hash of the lexical form of a string, returning a hexadecimal string representation of the hash."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-md5> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:md5 ( "hello" ) ]""" ;
	.

sparql:sha1
	a sh:ListParameterExpressionFunction ;
	rdfs:label "sha1"@en ;
	rdfs:comment "This function computes the SHA-1 hash of the lexical form of a string, returning a hexadecimal string representation of the result."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-sha1> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:sha1 ( "hello" ) ]""" ;
	.

sparql:sha256
	a sh:ListParameterExpressionFunction ;
	rdfs:label "sha256"@en ;
	rdfs:comment "This function computes the SHA-256 hash of the lexical form of a string, returning the resulting hash as a hexadecimal string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-sha256> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:sha256 ( "hello" ) ]""" ;
	.

sparql:sha384
	a sh:ListParameterExpressionFunction ;
	rdfs:label "sha384"@en ;
	rdfs:comment "This function computes the SHA-384 hash of the lexical form of a string, returning the resulting hexadecimal string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-sha384> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:sha384 ( "hello" ) ]""" ;
	.

sparql:sha512
	a sh:ListParameterExpressionFunction ;
	rdfs:label "sha512"@en ;
	rdfs:comment "This function computes the SHA-512 hash of the lexical form of a string, returning the result as a hexadecimal string."@en ;
	rdfs:isDefinedBy <http://www.w3.org/TR/sparql12-query/#func-sha512> ;
	rdfs:subClassOf sh:ListParameterExpression ;
	shnex-sparql:category "other" ;
	shnex-sparql:example """[ sparql:sha512 ( "hello" ) ]""" ;
	.
