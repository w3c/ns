perty is true, the results will be returned in descending order.\"@en ;","\trdfs:domain shnex:OrderByExpression ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy shnex: ;",".","shnex:orderBy","\ta rdf:Property ;","\trdfs:label \"remove\"@en ;","\trdfs:comment \"In Order By Expressions, this property specifies the node expression that produces the values that shall be used to compare the input nodes (sh:nodes).\"@en ;","\trdfs:domain shnex:OrderByExpression ;","\trdfs:isDefinedBy shnex: ;",".","","","# Path Values Expressions -----------------------------------------------------","","shnex:PathValuesExpression","\ta sh:NamedParameterExpressionFunction ;","\trdfs:label \"Path values expression\"@en ;","\trdfs:comment \"A SHACL node expression that returns the values of a given property path at the current focus node, or a computed focus node.\"@en ;","\trdfs:subClassOf sh:NamedParameterExpression ;","\tsh:parameter shnex:PathValuesExpression-pathValues ;","\tsh:parameter shnex:PathValuesExpression-focusNode ;","\trdfs:isDefinedBy shnex: ;",".","shnex:PathValuesExpression-pathValues","\ta sh:Parameter ;","\tsh:path shnex:pathValues ;","\tsh:keyParameter true ;","\trdfs:isDefinedBy shnex: ;",".","shnex:PathValuesExpression-focusNode","\ta sh:Parameter ;","\tsh:path shnex:focusNode ;","\tsh:name \"focus node\"@en ;","\tsh:description \"An optional node expression that produces the focus node.\"@en ;","\tsh:optional true ;","\trdfs:isDefinedBy shnex: ;",".","shnex:pathValues","\ta rdf:Property ;","\trdfs:label \"path values\"@en ;","\trdfs:comment \"In Path Values Expressions, this property specifies the property path.\"@en ;","\trdfs:domain shnex:PathValuesExpression ;","\trdfs:isDefinedBy shnex: ;",".","","","# Remove Expressions -----------------------------------------------------------","","shnex:RemoveExpression","\ta sh:NamedParameterExpressionFunction ;","\trdfs:label \"Remove expression\"@en ;","\trdfs:comment \"A SHACL node expression that returns the values o