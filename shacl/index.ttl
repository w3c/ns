hat must conform to the shape.\"@en ;","\trdfs:range xsd:integer ;","\trdfs:isDefinedBy sh: .","","sh:qualifiedValueShape","\ta rdf:Property ;","\trdfs:label \"qualified value shape\"@en ;","\trdfs:comment \"The shape that a specified number of values must conform to.\"@en ;","\trdfs:range sh:Shape ;","\trdfs:isDefinedBy sh: .","","sh:qualifiedValueShapesDisjoint","\ta rdf:Property ;","\trdfs:label \"qualified value shapes disjoint\"@en ;","\trdfs:comment \"Can be used to mark the qualified value shape to be disjoint with its sibling shapes.\"@en ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy sh: .","","","sh:ReifierShapeConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"ReifierShape constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to verify that the reifier conforms to a given shape.\"@en ;","\tsh:parameter sh:ReifierShapeConstraintComponent-reifierShape ;","\tsh:parameter sh:ReifierShapeConstraintComponent-reificationRequired ;","\trdfs:isDefinedBy sh: .","","sh:ReifierShapeConstraintComponent-reifierShape","\ta sh:Parameter ;","\tsh:path sh:reifierShape ;","\trdfs:isDefinedBy sh: .","","sh:ReifierShapeConstraintComponent-reificationRequired","\ta sh:Parameter ;","\tsh:path sh:reificationRequired ;","\tsh:datatype xsd:boolean ;","\tsh:optional true ;","\trdfs:isDefinedBy sh: .","","sh:reifierShape","\ta rdf:Property ;","\trdfs:label \"reifier shape\"@en ;","\trdfs:comment \"The shape that the reified triples must conform to.\"@en ;","\trdfs:range sh:NodeShape ;","\trdfs:isDefinedBy sh: .","","sh:reificationRequired","\ta rdf:Property ;","\trdfs:label \"reification required\"@en ;","\trdfs:comment \"Can be used to mark the reification statements required.\"@en ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy sh: .","","","sh:RootClassConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Root class constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to verify that each value node is the given class or a (transitive) subclass of that class.\"@en ;","\tsh:parameter sh:RootClassConstraintComponent-rootClass ;","\trdfs:isDefinedBy sh: .","","sh:RootClassConstraintComponent-rootClass","\ta sh:Parameter ;","\tsh:path sh:rootClass ;","\tsh:nodeKind sh:BlankNodeOrIRI ;","\trdfs:isDefinedBy sh: .","","sh:rootClass","\ta rdf:Property ;","\trdfs:label \"root class\"@en ;","\trdfs:comment \"Specifies a class so that each value node must be that class or a (transitive) subclass of that class.\"@en ;","\trdfs:isDefinedBy sh: .","","","sh:SingleLineConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Single line constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to specify that none of the value nodes may contain line breaks.\"@en ;","\tsh:parameter sh:SingleLineConstraintComponent-singleLine ;","\trdfs:isDefinedBy sh: .","","sh:SingleLineConstraintComponent-singleLine","\ta sh:Parameter ;","\tsh:path sh:singleLine ;","\tsh:datatype xsd:boolean ;","\tsh:maxCount 1 ;","\trdfs:isDefinedBy sh: .","","sh:singleLine","\ta rdf:Property ;","\trdfs:label \"single line\"@en ;","\trdfs:comment \"Specifies whether none of the value nodes may contain a line break.\"@en ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy sh: .","","","sh:SomeValueConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Some value constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to verify that at least one of the value nodes conform to the given shape.\"@en ;","\tsh:parameter sh:SomeValueConstraintComponent-someValue ;","\trdfs:isDefinedBy sh: .","","sh:SomeValueConstraintComponent-someValue","\ta sh:Parameter ;","\tsh:path sh:someValue ;","\trdfs:isDefinedBy sh: .","","sh:someValue","\ta rdf:Property ;","\trdfs:label \"some value\"@en ;","\trdfs:comment \"Specifies the shape that at least one value node must conform to.\"@en ;","\trdfs:range sh:Shape ;","\trdfs:isDefinedBy sh: .","","","sh:SubsetOfConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Subset-of constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to verify that the set of value nodes is a subset of the set of nodes that can be reached from the focus node using a given property path.\"@en ;","\tsh:parameter sh:SubsetOfConstraintComponent-subsetOf ;","\trdfs:isDefinedBy sh: .","","sh:SubsetOfConstraintComponent-subsetOf","\ta sh:Parameter ;","\tsh:path sh:subsetOf ;","\tsh:nodeKind sh:BlankNodeOrIRI ;","\trdfs:isDefinedBy sh: .","","sh:subsetOf","\ta rdf:Property ;","\trdfs:label \"subset of\"@en ;","\trdfs:comment \"Specifies a property path where the set of value nodes must be a subset of the values of that property path.\"@en ;","\trdfs:isDefinedBy sh: .","","","sh:UniqueLangConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Unique-languages constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to specify that no pair of value nodes may use the same language tag.\"@en ;","\tsh:parameter sh:UniqueLangConstraintComponent-uniqueLang ;","\trdfs:isDefinedBy sh: .","","sh:UniqueLangConstraintComponent-uniqueLang","\ta sh:Parameter ;","\tsh:path sh:uniqueLang ;","\tsh:datatype xsd:boolean ;","\tsh:maxCount 1 ;","\trdfs:isDefinedBy sh: .","","sh:uniqueLang","\ta rdf:Property ;","\trdfs:label \"unique languages\"@en ;","\trdfs:comment \"Specifies whether all node values must have a unique (or no) language tag.\"@en ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy sh: .","","","sh:UniqueValuesForConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Unique-values-for constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to ensure that no two nodes targeted by the same shape have the same combination of values for a given set of properties.\"@en ;","\tsh:parameter sh:UniqueValuesForConstraintComponent-uniqueValuesFor ;","\trdfs:isDefinedBy sh: .","","sh:UniqueValuesForConstraintComponent-uniqueValuesFor","\ta sh:Parameter ;","\tsh:path sh:uniqueValuesFor ;","\tsh:nodeKind sh:BlankNodeOrIRI ;","\trdfs:isDefinedBy sh: .","","sh:uniqueValuesFor","\ta rdf:Property ;","\trdfs:label \"unique values for\"@en ;","\trdfs:comment \"Specifies one or more properties (as a URI or rdf:List of URIs) for which no two nodes targeted by the same shape may have the same combination of values.\"@en ;","\trdfs:isDefinedBy sh: .","","","sh:XoneConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Exactly one constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to restrict the value nodes so that they conform to exactly one out of several provided shapes.\"@en ;","\tsh:parameter sh:XoneConstraintComponent-xone ;","\trdfs:isDefinedBy sh: .","","sh:XoneConstraintComponent-xone","\ta sh:Parameter ;","\tsh:path sh:xone ;","\trdfs:isDefinedBy sh: .","","sh:xone","\ta rdf:Property ;","\trdfs:label \"exactly one\"@en ;","\trdfs:comment \"Specifies a list of shapes so that the value nodes must conform to exactly one of the shapes.\"@en ;","\trdfs:range rdf:List ;    # members: sh:Shape ;","\trdfs:isDefinedBy sh: .","","","# Node Expressions ------------------------------------------------------------","","sh:NodeExpressionFunction","\ta rdfs:Class ;","\trdfs:label \"Node expression function\"@en ;","\trdfs:comment \"The base (meta) class of node expression functions.\"@en ;","\trdfs:subClassOf rdfs:Class ;","\trdfs:isDefinedBy sh: .","","sh:NamedParameterExpressionFunction","\ta rdfs:Class ;","\trdfs:label \"Named parameter expression function\"@en ;","\trdfs:comment \"The base class of node expression functions that take named parameters.\"@en ;","\trdfs:subClassOf sh:NodeExpressionFunction ;","\trdfs:subClassOf sh:Parameterizable ;","\trdfs:isDefinedBy sh: .","","sh:keyParameter","    a rdf:Property ;","\trdfs:label \"key parameter\"@en ;","\trdfs:comment \"Set to true for the parameter of a named parameter expression function that uniquely identifies it.\"@en ;","\trdfs:domain sh:Parameter ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy sh: .","","sh:ListParameterExpressionFunction","\ta rdfs:Class ;","\trdfs:label \"List parameter expression function\"@en ;","\trdfs:comment \"The base class of node expression functions that take a list of parameters.\"@en ;","\trdfs:subClassOf sh:NodeExpressionFunction ;","\trdfs:isDefinedBy sh: .","","sh:NodeExpression","\ta rdfs:Class ;","\trdfs:label \"Node expression\"@en ;","\trdfs:comment \"The base class of node expression (instances).\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","sh:NamedParameterExpression","\ta rdfs:Class ;","\trdfs:label \"Named parameter expression\"@en ;","\trdfs:comment \"The base class of node expressions (instances) that take named parameters.\"@en ;","\trdfs:subClassOf sh:NodeExpression ;","\trdfs:isDefinedBy sh: .","","sh:ListParameterExpression","\ta rdfs:Class ;","\trdfs:label \"List parameter expression\"@en ;","\trdfs:comment \"The base class of node expressions (instances) that take a list of parameters.\"@en ;","\trdfs:subClassOf sh:NodeExpression ;","\trdfs:isDefinedBy sh: .","","sh:bodyExpression","    a rdf:Property ;","\trdfs:label \"body expression\"@en ;","\trdfs:comment \"A node expression that is the implementation/body of a custom node expression function.\"@en ;","\trdfs:domain sh:NodeExpressionFunction ;","\trdfs:isDefinedBy sh: .","","","# General SPARQL execution support --------------------------------------------","","sh:SPARQLExecutable","\ta rdfs:Class ;","\trdfs:label \"SPARQL executable\"@en ;","\trdfs:comment \"The class of resources that encapsulate a SPARQL query.\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLAskExecutable","\ta rdfs:Class ;","\trdfs:label \"SPARQL ASK executable\"@en ;","\trdfs:comment \"The class of SPARQL executables that are based on an ASK query.\"@en ;","\trdfs:subClassOf sh:SPARQLExecutable ;","\trdfs:isDefinedBy sh: .","","sh:ask","\ta rdf:Property ;","\trdfs:label \"ask\"@en ;","\trdfs:comment \"The SPARQL ASK query to execute.\"@en ;","\trdfs:domain sh:SPARQLAskExecutable ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLConstructExecutable","\ta rdfs:Class ;","\trdfs:label \"SPARQL CONSTRUCT executable\"@en ;","\trdfs:comment \"The class of SPARQL executables that are based on a CONSTRUCT query.\"@en ;","\trdfs:subClassOf sh:SPARQLExecutable ;","\trdfs:isDefinedBy sh: .","","sh:construct","\ta rdf:Property ;","\trdfs:label \"construct\"@en ;","\trdfs:comment \"The SPARQL CONSTRUCT query to execute.\"@en ;","\trdfs:domain sh:SPARQLConstructExecutable ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLDescribeExecutable","\ta rdfs:Class ;","\trdfs:label \"SPARQL DESCRIBE executable\"@en ;","\trdfs:comment \"The class of SPARQL executables based on a SPARQL DESCRIBE.\"@en ;","\trdfs:subClassOf sh:SPARQLExecutable ;","\trdfs:isDefinedBy sh: .","","sh:describe","\ta rdf:Property ;","\trdfs:label \"describe\"@en ;","\trdfs:comment \"The SPARQL DESCRIBE to execute.\"@en ;","\trdfs:domain sh:SPARQLDescribeExecutable ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLSelectExecutable","\ta rdfs:Class ;","\trdfs:label \"SPARQL SELECT executable\"@en ;","\trdfs:comment \"The class of SPARQL executables based on a SELECT query.\"@en ;","\trdfs:subClassOf sh:SPARQLExecutable ;","\trdfs:isDefinedBy sh: .","","sh:select","\ta rdf:Property ;","\trdfs:label \"select\"@en ;","\trdfs:comment \"The SPARQL SELECT query to execute.\"@en ;","\trdfs:range xsd:string ;","\trdfs:domain sh:SPARQLSelectExecutable ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLUpdateExecutable","\ta rdfs:Class ;","\trdfs:label \"SPARQL UPDATE executable\"@en ;","\trdfs:comment \"The class of SPARQL executables based on a SPARQL UPDATE.\"@en ;","\trdfs:subClassOf sh:SPARQLExecutable ;","\trdfs:isDefinedBy sh: .","","sh:update","\ta rdf:Property ;","\trdfs:label \"update\"@en ;","\trdfs:comment \"The SPARQL UPDATE to execute.\"@en ;","\trdfs:domain sh:SPARQLUpdateExecutable ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:prefixes","\ta rdf:Property ;","\trdfs:label \"prefixes\"@en ;","\trdfs:comment \"The prefixes that shall be applied before parsing the associated SPARQL query. The objects should define those prefixes using sh:declare.\"@en ;","\trdfs:domain sh:SPARQLExecutable ;","\trdfs:isDefinedBy sh: .","","sh:PrefixDeclaration","\ta rdfs:Class ;","\trdfs:label \"Prefix declaration\"@en ;","\trdfs:comment \"The class of prefix declarations, consisting of pairs of a prefix with a namespace.\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","sh:declare","\ta rdf:Property ;","\trdfs:label \"declare\"@en ;","\trdfs:comment \"Links a resource with its namespace prefix declarations.\"@en ;","\trdfs:range sh:PrefixDeclaration ;","\trdfs:isDefinedBy sh: .","","sh:prefix","\ta rdf:Property ;","\trdfs:label \"prefix\"@en ;","\trdfs:comment \"The prefix of a prefix declaration.\"@en ;","\trdfs:domain sh:PrefixDeclaration ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:namespace","\ta rdf:Property ;","\trdfs:label \"namespace\"@en ;","\trdfs:comment \"The namespace associated with a prefix in a prefix declaration.\"@en ;","\trdfs:domain sh:PrefixDeclaration ;","\trdfs:range xsd:anyURI ;","\trdfs:isDefinedBy sh: .","","","# SPARQL-based Constraints support --------------------------------------------","","sh:SPARQLConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"SPARQL constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to define constraints based on SPARQL queries.\"@en ;","\tsh:parameter sh:SPARQLConstraintComponent-sparql ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLConstraintComponent-sparql","\ta sh:Parameter ;","\tsh:path sh:sparql ;","\trdfs:isDefinedBy sh: .","","sh:sparql","\ta rdf:Property ;","\trdfs:label \"constraint (in SPARQL)\"@en ;","\trdfs:comment \"Links a shape with SPARQL constraints.\"@en ;","\trdfs:domain sh:Shape ;","\trdfs:range sh:SPARQLConstraint ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLConstraint","\ta rdfs:Class ;","\trdfs:label \"SPARQL constraint\"@en ;","\trdfs:comment \"The class of constraints based on SPARQL SELECT queries.\"@en ;","\trdfs:subClassOf sh:SPARQLSelectExecutable ;","\trdfs:isDefinedBy sh: .","","","# SPARQL-based Node Expressions -----------------------------------------------","","sh:SelectExpression","\ta sh:NamedParameterExpressionFunction ;","\trdfs:label \"Select expression\"@en ;","\trdfs:comment \"The class of node expressions based on SPARQL SELECT queries.\"@en ;","\trdfs:subClassOf sh:NamedParameterExpression ;","\trdfs:subClassOf sh:SPARQLSelectExecutable ;","\tsh:parameter sh:SelectExpression-select ;","\tsh:parameter sh:SelectExpression-prefixes ;","\trdfs:isDefinedBy sh: .","","sh:SelectExpression-select","\ta sh:Parameter ;","\tsh:path sh:select ;","\tsh:name \"select\"@en ;","\tsh:description \"The SELECT query that is executed during evaluation of this node expression. The output nodes are the bindings of the first result variable.\"@en ;","\tsh:keyParameter true ;","\tsh:datatype xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:SelectExpression-prefixes","\ta sh:Parameter ;","\tsh:path sh:prefixes ;","\tsh:name \"prefixes\"@en ;","\tsh:description \"The prefixes that shall be applied before parsing the associated SPARQL query. The object should define those prefixes using sh:declare.\"@en ;","\tsh:nodeKind sh:BlankNodeOrIRI ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLExprExpression","\ta sh:NamedParameterExpressionFunction ;","\trdfs:label \"SPARQL expr expression\"@en ;","\trdfs:comment \"The class of node expressions based on SPARQL expressions (sh:sparqlExpr).\"@en ;","\trdfs:subClassOf sh:NamedParameterExpression ;","\trdfs:subClassOf sh:SPARQLExecutable ;","\tsh:parameter sh:SPARQLExprExpression-sparqlExpr ;","\tsh:parameter sh:SPARQLExprExpression-prefixes ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLExprExpression-sparqlExpr","\ta sh:Parameter ;","\tsh:path sh:sparqlExpr ;","\tsh:name \"SPARQL expr\"@en ;","\tsh:description \"The SPARQL expression that is executed during evaluation of this node expression.\"@en ;","\tsh:keyParameter true ;","\tsh:datatype xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLExprExpression-prefixes","\ta sh:Parameter ;","\tsh:path sh:prefixes ;","\tsh:name \"prefixes\"@en ;","\tsh:description \"The prefixes that shall be applied before parsing the SPARQL query that gets derived from the sh:sparqlExpr expression. The object should define those prefixes using sh:declare.\"@en ;","\tsh:nodeKind sh:BlankNodeOrIRI ;","\trdfs:isDefinedBy sh: .","","sh:sparqlExpr","\ta rdf:Property ;","\trdfs:label \"SPARQL expr\"@en ;","\trdfs:comment \"The SPARQL expression that is executed during evaluation of a node expression.\"@en ;","\trdfs:domain sh:SPARQLExprExpression ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","","# SPARQL-based Result Annotations ---------------------------------------------","","sh:resultAnnotation","\ta rdf:Property ;","\trdfs:label \"result annotation\"@en ;","\trdfs:comment \"Links a SPARQL validator with zero or more sh:ResultAnnotation instances, defining how to derive additional result properties based on the variables of the SELECT query.\"@en ;","\trdfs:domain sh:SPARQLSelectValidator ;","\trdfs:range sh:ResultAnnotation ;","\trdfs:isDefinedBy sh: .","","sh:ResultAnnotation","\ta rdfs:Class ;","\trdfs:label \"Result annotation\"@en ;","\trdfs:comment \"A class of result annotations, which define the rules to derive the values of a given annotation property as extra values for a validation result.\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","sh:annotationProperty","\ta rdf:Property ;","\trdfs:label \"annotation property\"@en ;","\trdfs:comment \"The annotation property that shall be set.\"@en ;","\trdfs:domain sh:ResultAnnotation ;","\trdfs:range rdf:Property ;","\trdfs:isDefinedBy sh: .","","sh:annotationValue","\ta rdf:Property ;","\trdfs:label \"annotation value\"@en ;","\trdfs:comment \"The (default) values of the annotation property.\"@en ;","\trdfs:domain sh:ResultAnnotation ;","\trdfs:isDefinedBy sh: .","","sh:annotationVarName","\ta rdf:Property ;","\trdfs:label \"annotation variable name\"@en ;","\trdfs:comment \"The name of the SPARQL variable from the SELECT clause that shall be used for the values.\"@en ;","\trdfs:domain sh:ResultAnnotation ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","","# Constraints based on Node Expressions ---------------------------------------","","sh:ExpressionConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Expression constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to verify that a given node expression produces true for all value nodes.\"@en ;","\tsh:parameter sh:ExpressionConstraintComponent-expression ;","\trdfs:isDefinedBy sh: .","","sh:ExpressionConstraintComponent-expression","\ta sh:Parameter ;","\tsh:path sh:expression ;","\trdfs:isDefinedBy sh: .","","sh:expression","\ta rdf:Property ;","\trdfs:label \"expression\"@en ;","\trdfs:comment \"The node expression that must return true for the value nodes.\"@en ;","\trdfs:isDefinedBy sh: .","","","sh:NodeByExpressionConstraintComponent","\ta sh:ConstraintComponent ;","\trdfs:label \"Node by expression constraint component\"@en ;","\trdfs:comment \"A constraint component that can be used to verify that all value nodes conform to the node shape(s) produced by the given node expression.\"@en ;","\tsh:parameter sh:NodeByExpressionConstraintComponent-nodeByExpression ;","\trdfs:isDefinedBy sh: .","","sh:NodeByExpressionConstraintComponent-nodeByExpression","\ta sh:Parameter ;","\tsh:path sh:nodeByExpression ;","\trdfs:isDefinedBy sh: .","","sh:nodeByExpression","\ta rdf:Property ;","\trdfs:label \"node by expression\"@en ;","\trdfs:comment \"Links a shape to node expressions, indicating the node shape(s) that all value nodes must conform to.\"@en ;","\t# rdfs:range sh:NodeShape ; (node expression)","\trdfs:isDefinedBy sh: .","","","# Non-validating constraint properties ----------------------------------------","","sh:agentInstruction","\ta rdf:Property ;","\trdfs:label \"agent instruction\"@en ;","\trdfs:comment \"Can be used to store instructions that shall be sent as input for external agents that understand natural language.\"@en ;","\t# range: xsd:string or rdf:langString or rdf:dirLangString","\trdfs:isDefinedBy sh: .","","sh:codeIdentifier","\ta rdf:Property ;","\trdfs:label \"code identifier\"@en ;","\trdfs:comment \"A hint on how code generators should represent the associated shape.\"@en ;","\trdfs:domain sh:Shape ;","\trdfs:range xsd:string ;","\trdfs:isDefinedBy sh: .","","sh:defaultValue","\ta rdf:Property ;","\trdfs:label \"default value\"@en ;","\trdfs:comment \"A default value for a property, for example for user interface tools to pre-populate input fields.\"@en ;","\trdfs:domain sh:PropertyShape ;","\trdfs:isDefinedBy sh: .","","sh:description","\ta rdf:Property ;","\trdfs:label \"description\"@en ;","\trdfs:comment \"Human-readable descriptions for the property in the context of the surrounding shape.\"@en ;","\trdfs:domain sh:PropertyShape ;","\t# range: xsd:string or rdf:dirLangString or rdf:langString or rdf:HTML","\trdfs:isDefinedBy sh: .","","sh:formalized","\ta rdf:Property ;","\trdfs:label \"formalized\"@en ;","\trdfs:comment \"Can be used as reification of sh:intent triples to indicate whether the intended interpretation has already been formalized using SHACL in the same shapes graph.\"@en ;","\trdfs:range xsd:boolean ;","\trdfs:isDefinedBy sh: .","","sh:group","\ta rdf:Property ;","\trdfs:label \"group\"@en ;","\trdfs:comment \"Can be used to link to a property group to indicate that a property shape belongs to a group of related property shapes.\"@en ;","\trdfs:domain sh:PropertyShape ;","\trdfs:range sh:PropertyGroup ;","\trdfs:isDefinedBy sh: .","","sh:intent","\ta rdf:Property ;","\trdfs:label \"intent\"@en ;","\trdfs:comment \"Provides human-readable descriptions of one or more intended rules, assumptions, or constraints associated with its subject (e.g., a shape). Can be used as input for external agents that understand natural language.\"@en ;","\t# range: xsd:string or rdf:langString or rdf:dirLangString","\trdfs:isDefinedBy sh: .","","sh:name","\ta rdf:Property ;","\trdfs:label \"name\"@en ;","\trdfs:comment \"Human-readable labels for the property in the context of the surrounding shape.\"@en ;","\trdfs:domain sh:PropertyShape ;","\t# range: xsd:string or rdf:dirLangString or rdf:langString","\trdfs:isDefinedBy sh: .","","sh:order","\ta rdf:Property ;","\trdfs:label \"order\"@en ;","\trdfs:comment \"Specifies the relative order of this compared to its siblings. For example use 0 for the first, 1 for the second.\"@en ;","\t# range: xsd:decimal or xsd:integer ;","\trdfs:isDefinedBy sh: .","","sh:unit","\ta rdf:Property ;","\trdfs:label \"unit\"@en ;","\trdfs:comment \"The code of a unit that the (literal) value nodes should be interpreted with. Recommended values are plain strings from the UCUM and ISO 4217 standards for units of measure and currencies respectively, or unit URIs from QUDT or a similar ontology.\"@en ;","\trdfs:domain sh:Shape ;","\trdfs:isDefinedBy sh: .","","sh:PropertyGroup","\ta rdfs:Class ;","\trdfs:label \"Property group\"@en ;","\trdfs:comment \"Instances of this class represent groups of property shapes that belong together.\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","","# -----------------------------------------------------------------------------","# SHACL ADVANCED FEATURES (will likely be marked deprecated with 1.2)","# -----------------------------------------------------------------------------","","","# Advanced Target vocabulary --------------------------------------------------","","sh:target","\ta rdf:Property ;","\trdfs:label \"target\"@en ;","\trdfs:comment \"Links a shape to a target specified by an extension language, for example instances of sh:SPARQLTarget.\"@en ;","\trdfs:domain sh:Shape ;","\trdfs:range sh:Target ;","\trdfs:isDefinedBy sh: .","","sh:Target","\ta rdfs:Class ;","\trdfs:label \"Target\"@en ;","\trdfs:comment \"The base class of targets such as those based on SPARQL queries.\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","sh:TargetType","\ta rdfs:Class ;","\trdfs:label \"Target type\"@en ;","\trdfs:comment \"The (meta) class for parameterizable targets.\tInstances of this are instantiated as values of the sh:target property.\"@en ;","\trdfs:subClassOf rdfs:Class ;","\trdfs:subClassOf sh:Parameterizable ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLTarget","\ta rdfs:Class ;","\trdfs:label \"SPARQL target\"@en ;","\trdfs:comment \"The class of targets that are based on SPARQL queries.\"@en ;","\trdfs:subClassOf sh:Target ;","\trdfs:subClassOf sh:SPARQLAskExecutable ;","\trdfs:subClassOf sh:SPARQLSelectExecutable ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLTargetType","\ta rdfs:Class ;","\trdfs:label \"SPARQL target type\"@en ;","\trdfs:comment \"The (meta) class for parameterizable targets that are based on SPARQL queries.\"@en ;","\trdfs:subClassOf sh:TargetType ;","\trdfs:subClassOf sh:SPARQLAskExecutable ;","\trdfs:subClassOf sh:SPARQLSelectExecutable ;","\trdfs:isDefinedBy sh: .","","","# Functions Vocabulary --------------------------------------------------------","","sh:Function","\ta rdfs:Class ;","\trdfs:label \"Function\"@en ;","\trdfs:comment \"The class of SHACL functions.\"@en ;","\trdfs:subClassOf sh:Parameterizable ;","\trdfs:isDefinedBy sh: .","","sh:returnType","\ta rdf:Property ;","\trdfs:label \"return type\"@en ;","\trdfs:comment \"The expected type of values returned by the associated function.\"@en ;","\trdfs:domain sh:Function ;","\trdfs:range rdfs:Class ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLFunction","\ta rdfs:Class ;","\trdfs:label \"SPARQL function\"@en ;","\trdfs:comment \"A function backed by a SPARQL query - either ASK or SELECT.\"@en ;","\trdfs:subClassOf sh:Function ;","\trdfs:subClassOf sh:SPARQLAskExecutable ;","\trdfs:subClassOf sh:SPARQLSelectExecutable ;","\trdfs:isDefinedBy sh: .","","","# Node Expressions ------------------------------------------------------------","","sh:this","\trdfs:comment \"Deprecated with SHACL 1.2: replaced by shnex:var.\"@en .","","sh:filterShape","\trdfs:comment \"Deprecated with SHACL 1.2: replaced by shnex:filterShape.\"@en .","","sh:nodes","\trdfs:comment \"Deprecated with SHACL 1.2: replaced by shnex:nodes.\"@en .","","sh:intersection","\trdfs:comment \"Deprecated with SHACL 1.2: replaced by shnex:intersection.\"@en .","","sh:union","\trdfs:comment \"Deprecated with SHACL 1.2: replaced by shnex:concat.\"@en .","","sh:minus","\trdfs:comment \"Deprecated with SHACL 1.2: replaced by shnex:remove.\"@en .","","","# Rules -----------------------------------------------------------------------","","sh:Rule","\ta rdfs:Class ;","\trdfs:label \"Rule\"@en ;","\trdfs:comment \"The class of SHACL rules. Never instantiated directly.\"@en ;","\trdfs:subClassOf rdfs:Resource ;","\trdfs:isDefinedBy sh: .","","sh:rule","\ta rdf:Property ;","\trdfs:label \"rule\"@en ;","\trdfs:comment \"The rules linked to a shape.\"@en ;","\trdfs:domain sh:Shape ;","\trdfs:range sh:Rule ;","\trdfs:isDefinedBy sh:  .","","sh:condition","\ta rdf:Property ;","\trdfs:label \"condition\"@en ;","\trdfs:comment \"The shapes that the focus nodes need to conform to before a rule is executed on them.\"@en ;","\trdfs:domain sh:Rule ;","\trdfs:range sh:Shape ;","\trdfs:isDefinedBy sh: .","","sh:TripleRule","\ta rdfs:Class ;","\trdfs:label \"Triple rule\"@en ;","\trdfs:comment \"A rule based on triple (subject, predicate, object) pattern.\"@en ;","\trdfs:subClassOf sh:Rule ;","\trdfs:isDefinedBy sh: .","","sh:subject","\ta rdf:Property ;","\trdfs:label \"subject\"@en ;","\trdfs:comment \"An expression producing the resources that shall be inferred as subjects.\"@en ;","\trdfs:domain sh:TripleRule ;","\trdfs:isDefinedBy sh: .","","sh:predicate","\ta rdf:Property ;","\trdfs:label \"predicate\"@en ;","\trdfs:comment \"An expression producing the properties that shall be inferred as predicates.\"@en ;","\trdfs:domain sh:TripleRule ;","\trdfs:isDefinedBy sh: .","","sh:object","\ta rdf:Property ;","\trdfs:label \"object\"@en ;","\trdfs:comment \"An expression producing the nodes that shall be inferred as objects.\"@en ;","\trdfs:domain sh:TripleRule ;","\trdfs:isDefinedBy sh: .","","sh:SPARQLRule","\ta rdfs:Class ;","\trdfs:label \"SPARQL CONSTRUCT rule\"@en ;","\trdfs:comment \"The class of SHACL rules based on SPARQL CONSTRUCT queries.\"@en ;","\trdfs:subClassOf sh:Rule ;","\trdfs:subClassOf sh:SPARQLConstructExecutable ;","\trdfs:isDefinedBy sh: ."],"stylingDirectives":[[[0,47,"pl-c"],[0,1,"pl-c"]],[[0,75,"pl-c"],[0,1,"pl-c"]],[[0,11,"pl-c"],[0,1,"pl-c"]],[],[[0,51,"pl-c"],[0,1,"pl-c"]],[],[[0,69,"pl-c"],[0,1,"pl-c"]],[],[[0,7,"pl-k"],[14,46,"pl-en"]],[[0,7,"pl-k"],[14,59,"pl-en"]],[[0,7,"pl-k"],[14,53,"pl-en"]],[[0,7,"pl-k"],[14,49,"pl-en"]],[[0,7,"pl-k"],[16,37,"pl-en"]],[[0,7,"pl-k"],[14,43,"pl-en"]],[],[],[[1,2,"pl-k"]],[],[[12,66,"pl-s"],[12,13,"pl-pds"],[62,63,"pl-pds"],[63,66,"pl-c1"]],[[14,99,"pl-s"],[14,15,"pl-pds"],[95,96,"pl-pds"],[96,99,"pl-c1"]],[[19,50,"pl-s"],[19,20,"pl-pds"],[49,50,"pl-pds"]],[[4,39,"pl-c"],[4,39,"pl-c"]],[[4,38,"pl-c"],[4,38,"pl-c"]],[[4,40,"pl-c"],[4,40,"pl-c"]],[[19,105,"pl-s"],[19,20,"pl-pds"],[92,93,"pl-pds"],[93,105,"pl-k"]],[[19,24,"pl-s"],[19,20,"pl-pds"],[23,24,"pl-pds"]],[],[[12,16,"pl-s"],[12,13,"pl-pds"],[15,16,"pl-pds"]],[[15,56,"pl-s"],[15,16,"pl-pds"],[43,44,"pl-pds"],[44,56,"pl-k"]],[],[[25,60,"pl-en